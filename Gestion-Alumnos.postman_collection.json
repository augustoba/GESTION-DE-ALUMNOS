    {
      "name": "6. Validaciones - Casos de error",
      "item": [
        {
          "name": "Registro - nombre con numeros (debe fallar)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Juan123\",\n  \"apellidos\": \"Perez\",\n  \"dni\": \"12345678\",\n  \"email\": \"juan@gmail.com\",\n  \"password\": \"pass123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/registro",
              "host": ["{{base_url}}"],
              "path": ["auth", "registro"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
