    {
      "name": "4. Administracion - Preinscripciones",
      "item": [
        {
          "name": "Listar todas (paginado)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/preinscripciones?page=0&size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "preinscripciones"],
              "query": [
                { "key": "page", "value": "0",  "description": "Numero de pagina (desde 0)" },
                { "key": "size", "value": "20", "description": "Resultados por pagina" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Lista paginada devuelta', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    var page = jsonData.data;",
                  "    pm.expect(page).to.have.property('content');",
                  "    pm.expect(page).to.have.property('totalElements');",
                  "    pm.expect(page).to.have.property('totalPages');",
                  "    console.log('Total preinscripciones: ' + page.totalElements);",
                  "    console.log('Total paginas: ' + page.totalPages);",
                  "    if (page.content.length > 0) {",
                  "        pm.collectionVariables.set('preinscripcion_id', page.content[0].id);",
                  "        console.log('preinscripcion_id actualizado: ' + page.content[0].id);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
