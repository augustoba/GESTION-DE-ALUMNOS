    {
      "name": "2. Preinscripcion (Alumno)",
      "item": [
        {
          "name": "Crear preinscripcion",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "nombre",          "value": "Juan",                    "type": "text", "description": "Sin numeros" },
                { "key": "apellido",        "value": "Perez",                   "type": "text", "description": "Sin numeros" },
                { "key": "dni",             "value": "12345678",                "type": "text", "description": "Minimo 8 digitos numericos" },
                { "key": "email",           "value": "juan.perez@gmail.com",    "type": "text" },
                { "key": "telefono",        "value": "1123456789",              "type": "text" },
                { "key": "direccion",       "value": "Av. Corrientes 1234",     "type": "text" },
                { "key": "fechaNacimiento", "value": "1995-08-20",              "type": "text", "description": "Formato YYYY-MM-DD" },
                { "key": "carreraId",       "value": "1",                       "type": "text", "description": "1=Desarrollo Software, 2=Gestion Eventos, 3=Administracion Empresas" },
                { "key": "comprobante",     "type": "file", "src": "",          "description": "Foto o PDF del comprobante de pago" },
                { "key": "dniFente",        "type": "file", "src": "",          "description": "JPG o PNG del frente del DNI" },
                { "key": "dniDorso",        "type": "file", "src": "",          "description": "JPG o PNG del dorso del DNI" },
                { "key": "titulo",          "type": "file", "src": "",          "description": "PDF del titulo secundario" },
                { "key": "fotoCarnet",      "type": "file", "src": "",          "description": "JPG o PNG foto carnet (fondo blanco)" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/preinscripciones",
              "host": ["{{base_url}}"],
              "path": ["api", "preinscripciones"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Preinscripcion creada y ID guardado', function () {",
                  "    pm.response.to.have.status(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.collectionVariables.set('preinscripcion_id', jsonData.data.id);",
                  "    console.log('preinscripcion_id guardado: ' + jsonData.data.id);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
